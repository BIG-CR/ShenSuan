  "驿马": {
    "description": "主动态、奔波、迁移、出国。驿马逢冲则动，逢合则止。以年支或日支起。",
    "rule": {
      "申子辰": "寅",
      "亥卯未": "巳",
      "寅午戌": "申",
      "巳酉丑": "亥"
    },
    "口诀": "申子辰马在寅，亥卯未马在巳，寅午戌马在申，巳酉丑马在亥。"
  },
  "桃花（咸池）": {
    "description": "主人缘、异性缘、艺术才华。桃花过旺需注意感情纠葛。以年支或日支起。",
