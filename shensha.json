      "丙": "申",
      "丁": "酉",
      "戊": "申",
      "己": "酉",
      "庚": "亥",
      "辛": "子",
      "壬": "寅",
      "癸": "卯"
    },
    "口诀": "甲巳乙午报君知，丙戊申宫丁己鸡，庚猪辛鼠壬逢虎，癸人见卯入云梯。"
  },
  "学堂": {
    "description": "主学业有成，智力超群。以日干起，见长生之位即是。",
    "rule": {
      "甲": "亥",
      "乙": "午",
      "丙": "寅",
      "丁": "酉",
      "戊": "寅",
      "己": "酉",
      "庚": "巳",
      "辛": "子",
      "壬": "申",
      "癸": "卯"
    }
