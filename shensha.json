{
  "description": "神煞速查表 — 包含天乙贵人、文昌、驿马、桃花、华盖、将星、禄神、羊刃等常用神煞的起法规则与查表。",
  "天乙贵人": {
    "description": "逢凶化吉之星，关键时刻有贵人相助。以日干或年干起。",
    "rule": {
      "甲": ["丑", "未"],
      "戊": ["丑", "未"],
      "庚": ["丑", "未"],
      "乙": ["子", "申"],
      "己": ["子", "申"],
      "丙": ["亥", "酉"],
      "丁": ["亥", "酉"],
      "辛": ["午", "寅"],
      "壬": ["卯", "巳"],
      "癸": ["卯", "巳"]
    },
    "口诀": "甲戊庚牛羊，乙己鼠猴乡，丙丁猪鸡位，壬癸兔蛇藏，六辛逢虎马，此是贵人方。"
  },
  "文昌贵人": {
    "description": "主聪明好学、文采出众、利考试功名。以日干或年干起。",
